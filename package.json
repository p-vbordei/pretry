{
  "name": "@p-vbordei/pretry",
  "version": "0.1.0",
  "description": "Promise retry with exponential backoff, jitter, AbortSignal cancellation, and a custom retriable predicate. Zero dependencies.",
  "keywords": [
    "retry",
    "backoff",
    "promise",
    "abort",
    "fetch"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=20"
  },
  "author": {
    "name": "Vlad Bordei",
    "email": "bordeivlad@gmail.com",
    "url": "https://github.com/p-vbordei"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/p-vbordei/pretry.git"
  },
  "bugs": {
    "url": "https://github.com/p-vbordei/pretry/issues"
  },
  "homepage": "https://github.com/p-vbordei/pretry#readme",
  "devDependencies": {
    "typescript": "^5.5.0",
    "vitest": "^4.1.6"
  }
}
